apiVersion: barmancloud.cnpg.io/v1
kind: ObjectStore
metadata:
  name: garage-store-recovery
  namespace: databases
spec:
  configuration:
    destinationPath: s3://cnpg/
    endpointURL: http://garage.databases.svc.cluster.local:3900
    s3Credentials:
      accessKeyId:
        name: cloudnative-pg-secret
        key: ACCESS_KEY_ID
      secretAccessKey:
        name: cloudnative-pg-secret
        key: CNPG_BUCKET_SEC
    data:
      compression: gzip
    wal:
      compression: zstd
      maxParallel: 8
  instanceSidecarConfiguration:
    env:
      - name: AWS_REQUEST_CHECKSUM_CALCULATION
        value: when_required
      - name: AWS_RESPONSE_CHECKSUM_VALIDATION
        value: when_required
    resources:
      requests:
        cpu: 70m
        memory: 250Mi
      limits:
        memory: 900Mi
