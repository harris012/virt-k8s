---
# yaml-language-server: $schema=https://kubernetes-schemas.pages.dev/helm.toolkit.fluxcd.io/helmrelease_v2.json
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: keda-add-ons-http
spec:
  chartRef:
    kind: OCIRepository
    name: keda-add-ons-http
  interval: 1h
  install:
    crds: CreateReplace
  upgrade:
    crds: CreateReplace
  values:  # https://github.com/kedacore/charts/tree/main/http-add-on#configuration
    interceptor:
      pullPolicy: IfNotPresent
      replicas:
        min: 1
        max: 2
      resources:
        requests:
          cpu: 10m
          memory: 64Mi
        limits:
          memory: 256Mi
    scaler:
      replicas: 1
      pullPolicy: IfNotPresent
      resources:
        requests:
          cpu: 10m
          memory: 64Mi
        limits:
          memory: 128Mi
      crds:
        install: true
    logging:
      operator:
        level: info
        format: console
      scaler:
        level: info
        format: console
      interceptor:
        level: info
        format: console

    operator:
      replicas: 1
      pullPolicy: IfNotPresent
      resources:
        requests:
          cpu: 10m
          memory: 64Mi
        limits:
          memory: 128Mi
